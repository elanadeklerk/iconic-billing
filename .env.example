# ── Copy this file to .env and fill in your real values ──
# NEVER commit .env to git

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Supabase (from your Supabase project settings) ──────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# ── Admin ────────────────────────────────────────────────
# This email is the only one that can access the admin panel
ADMIN_EMAIL=admin@iconicbilling.co.za

# ── JWT Secret ───────────────────────────────────────────
# Used to verify Supabase JWTs server-side (from Supabase project settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Anthropic ────────────────────────────────────────────
# ONE shared Anthropic key for all doctors (stored server-side only)
# This replaces the per-doctor anthropic_key in the database
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx

# ── Google Service Account ───────────────────────────────
# Paste the ENTIRE contents of your service account JSON key file as one line.
# In the JSON, newlines in private_key are stored as literal \n — that's correct.
# Share each doctor's Google Sheet with the service account's client_email as Viewer.
# Example:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"iconic-flow@your-project.iam.gserviceaccount.com",...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Per-doctor config ────────────────────────────────────
# intake_sheet_id and apps_script_url remain per-doctor in Supabase.
# google_key is no longer needed — service account replaces API keys.
